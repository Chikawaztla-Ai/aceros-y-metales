# ============================================================
# acerosymetalesurgentes.com — Variables de entorno
# Copia a .env.local y completa con tus credenciales.
# ============================================================

# --- Sitio ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WA_NUMBER=5215519232398

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # ¡SÓLO servidor! nunca exponer

# --- Mercado Pago (Checkout Pro) ---
# Test: usa credenciales de prueba. Prod: credenciales productivas.
MP_ACCESS_TOKEN=                      # Access Token (servidor)
MP_WEBHOOK_SECRET=                    # Secret del webhook (para validar x-signature)
NEXT_PUBLIC_MP_PUBLIC_KEY=            # Public Key (opcional, para Bricks V2)

# --- Resend (emails transaccionales) ---
RESEND_API_KEY=
EMAIL_FROM=Aceros y Metales Urgentes <pedidos@acerosymetalesurgentes.com>
ADMIN_EMAIL=ventas@acerosymetalesurgentes.com

# --- Datos bancarios para transferencia (servidor) ---
BANK_NAME=BBVA México
BANK_BENEFICIARY=Aceros y Metales Urgentes S.A. de C.V.
BANK_CLABE=012180000000000000
BANK_ACCOUNT=0000000000
